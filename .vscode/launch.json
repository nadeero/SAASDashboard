{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: run.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "console": "integratedTerminal",
      "env": { "FLASK_ENV": "development" }
    },
    {
      "name": "Seed database",
      "type": "debugpy",
      "request": "launch",
      "module": "app.etl.seed",
      "console": "integratedTerminal"
    },
    {
      "name": "Pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal"
    }
  ]
}
